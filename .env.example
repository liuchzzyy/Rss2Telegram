# Personal Telegram settings. Copy this file to .env and fill private values.
BOT_TOKEN=
DESTINATIONS=
TOPIC=none

# Message formatting.
MESSAGE_TEMPLATE={EMOJI} <b>{TITLE}</b>\n{LINK}
BUTTON_TEXT={SITE_NAME}
HIDE_BUTTON=false
PARAMETERS=
ENABLE_TELEGRAPH=false
TELEGRAPH_TOKEN=none
EMOJIS=🗞️,📰,📡,📬,📌,🔖,🔗,📝,📋,📚,💡,⚙️,🧠,🚀,✨,🌐,📊,🎧,🎬,🧪

# Feed and runtime settings.
OPML_FILE=Subscriptions.opml
DATABASE=rss2telegram.db
MAX_ENTRIES_PER_FEED=100
SEND_ON_FIRST_RUN=false
FETCH_IMAGES=true
REQUEST_TIMEOUT=10
SLEEP_BETWEEN_MESSAGES=0.2
